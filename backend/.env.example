FIREWORKS_API_KEY=your-fireworks-api-key-here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Postgres only. docker compose sets the in-network host (db); this localhost
# form is for running the API against the compose Postgres from the host.
DATABASE_URL=postgresql+asyncpg://claims:claims@localhost:5432/claims

# Local GPU backend (OpenAI-compatible: vLLM/Ollama/llama.cpp). Leave blank
# until the AMD droplet is serving; then point the model_* specs at "local:...".
LOCAL_BASE_URL=
LOCAL_API_KEY=

# Per-role model as "provider:model". Flip cloud<->local by editing the value.
MODEL_CLASSIFIER=fireworks:accounts/fireworks/models/gpt-oss-20b
MODEL_EXTRACTOR=fireworks:accounts/fireworks/models/gpt-oss-20b
