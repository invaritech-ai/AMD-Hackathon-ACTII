# Required. Use a URL-safe value because it is interpolated into DATABASE_URL.
POSTGRES_PASSWORD=replace-with-a-long-random-alphanumeric-password
FIREWORKS_API_KEY=replace-with-your-fireworks-api-key

# Optional overrides
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
IMAGE_TAG=latest
LOCAL_BASE_URL=
LOCAL_API_KEY=
MODEL_CLASSIFIER=fireworks:accounts/fireworks/models/gpt-oss-20b
MODEL_EXTRACTOR=fireworks:accounts/fireworks/models/gpt-oss-20b
MODEL_VISION_OCR=fireworks:accounts/fireworks/models/kimi-k2p7-code
MODEL_OCR_CLEANUP=fireworks:accounts/fireworks/models/gpt-oss-120b
MODEL_VISION_CLASSIFIER=fireworks:accounts/fireworks/models/qwen3p7-plus
